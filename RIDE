<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ride Nippy Private Limited Logo</title>

<style>

  body{
    margin:0;
    height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:#f6f7fb;
    font-family:"Segoe UI",sans-serif;
  }

  /* LOGO CONTAINER */

  .logo-wrap{

    display:flex;
    align-items:center;
    gap:24px;

    padding:28px 34px;

    background:white;

    border-radius:30px;

    box-shadow:
      0 18px 40px rgba(0,0,0,0.08);

  }

  /* TEXT */

  .logo-text h1{

    margin:0;

    font-size:42px;

    line-height:1;

    letter-spacing:-1.8px;

    color:#1f1f1f;

    font-weight:800;

  }

  .logo-text p{

    margin-top:10px;

    color:#6d6d78;

    font-size:14px;

    letter-spacing:2px;

    text-transform:uppercase;

  }

  /* SVG ANIMATION */

  .logo-icon{

    width:120px;
    height:120px;

    animation:float 4s ease-in-out infinite;

  }

  @keyframes float{

    0%{
      transform:translateY(0px);
    }

    50%{
      transform:translateY(-6px);
    }

    100%{
      transform:translateY(0px);
    }

  }

</style>
</head>

<body>

<div class="logo-wrap">

  <!-- SVG LOGO -->

  <svg class="logo-icon"
       viewBox="0 0 200 200"
       xmlns="http://www.w3.org/2000/svg">

    <!-- OUTER ORGANIC SHAPE -->

    <defs>

      <linearGradient id="grad1"
        x1="0%" y1="0%"
        x2="100%" y2="100%">

        <stop offset="0%"
          stop-color="#ff9f43"/>

        <stop offset="100%"
          stop-color="#ff5e57"/>

      </linearGradient>

      <linearGradient id="leafGrad"
        x1="0%" y1="0%"
        x2="100%" y2="100%">

        <stop offset="0%"
          stop-color="#7ed957"/>

        <stop offset="100%"
          stop-color="#3cb371"/>

      </linearGradient>

    </defs>

    <!-- MAIN FLOW SHAPE -->

    <path
      d="M100 22
         C145 20 178 55 176 98
         C174 146 138 178 92 176
         C50 174 20 144 22 98
         C24 52 54 24 100 22Z"

      fill="url(#grad1)"
    />

    <!-- INNER FLOW -->

    <path
      d="M70 70
         C92 42 136 52 140 88
         C144 122 110 146 82 130
         C104 122 120 108 118 88
         C116 68 96 62 70 70Z"

      fill="white"
      opacity="0.95"
    />

    <!-- LEAF -->

    <path
      d="M112 42
         C128 26 152 28 162 46
         C142 54 126 56 112 42Z"

      fill="url(#leafGrad)"
    />

  </svg>

  <!-- BRAND TEXT -->

  <div class="logo-text">

    <h1>Ride Nippy</h1>

    <p>
      Pickles • Vinegar • Fruit Jam • Edible Oil
    </p>

  </div>

</div>

</body>
</html>
